# Replicate API token. Leave empty until you are ready to call Replicate.
REPLICATE_API_TOKEN=
# Directory where downloaded generated images and metadata are stored.
IMAGEGEN_OUTPUT_DIR=data/images
# SQLite database path for durable generation request history.
IMAGEGEN_DB_PATH=data/imagegen.sqlite3
# Optional Immich server URL for uploading gallery images.
IMMICH_URL=
# Optional Immich album id to attach uploaded images to.
IMMICH_GALLERY_ID=
# Optional Immich API key. Required permissions: asset.upload and albumAsset.create.
IMMICH_API_KEY=
# Default model alias. Options: flux-flex, seedream45.
IMAGEGEN_MODEL=seedream45
# Flask secret key for local development. Replace for shared deployments.
IMAGEGEN_FLASK_SECRET_KEY=dev-secret-change-me
# Seconds between Replicate prediction polling requests.
IMAGEGEN_REPLICATE_POLL_SECONDS=1.0
# Maximum seconds to wait for a Replicate prediction before timing out.
IMAGEGEN_REPLICATE_TIMEOUT_SECONDS=60.0
