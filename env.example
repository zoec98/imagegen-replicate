# Add your replicate.com API token here
REPLICATE_API_TOKEN=

# Add your fal.ai API key here
FAL_KEY=

# Directory where runtime data, images, palettes, trash, and SQLite live.
IMAGEGEN_DATA_DIR=data

# Days to keep trash before automatic purge. Use 0 to disable.
TRASHCAN_HOLD_LIMIT_DAYS=7

# Author name embedded in generated image metadata.
AUTHOR=Noname Changeme Nescio

# Default model alias. Options: seedream45.
IMAGEGEN_MODEL=seedream45

# Flask secret key for browser sessions. Generated automatically by setup.
IMAGEGEN_FLASK_SECRET_KEY=

# Seconds between Replicate prediction polling requests.
IMAGEGEN_REPLICATE_POLL_SECONDS=1.0

# Maximum seconds to wait for a Replicate prediction before timing out.
IMAGEGEN_REPLICATE_TIMEOUT_SECONDS=60.0

# Optional Immich server URL for importing from or uploading to Immich.
IMMICH_URL=https://immich.example.com

# Optional Immich album id to attach local gallery uploads to.
# This is not used for browsing the Immich main gallery.
# For an existing upload album, it will be the UUID at the end:
# https://immich.example.com/albums/<this_uuid_copied>
IMMICH_UPLOAD_ALBUM_ID=

# Optional Immich API key.
# Main-gallery import needs asset.read, asset.view, and asset.download.
# Uploading local gallery images to Immich also needs asset.upload and albumAsset.create.
IMMICH_API_KEY=
