# Add your replicate.com API token here
REPLICATE_API_TOKEN=

# Directory where runtime data, images, palettes, trash, and SQLite live.
IMAGEGEN_DATA_DIR=data

# Author name embedded in generated image metadata.
AUTHOR=Noname Changeme Nescio

# Default model alias. Options: seedream45.
IMAGEGEN_MODEL=seedream45

# Flask secret key for local development. Replace for shared deployments.
IMAGEGEN_FLASK_SECRET_KEY=dev-secret-change-me

# Seconds between Replicate prediction polling requests.
IMAGEGEN_REPLICATE_POLL_SECONDS=1.0

# Maximum seconds to wait for a Replicate prediction before timing out.
IMAGEGEN_REPLICATE_TIMEOUT_SECONDS=60.0

# Optional Immich server URL for uploading gallery images; we will call this + /api
IMMICH_URL=https://immich.example.com

# Optional Immich album id to attach uploaded images to.
# For an existing album, it will be the UUID at the end:
# https://immich.example.com/albumbs/<this_uuid_copied>
IMMICH_GALLERY_ID=

# Optional Immich API key. Required permissions: asset.upload and albumAsset.create.
# recommended: asset.download,asset.upload,album.create,album.read,albumAsset.create,tag.*
IMMICH_API_KEY=
