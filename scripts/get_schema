#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -ne 1 ]; then
    printf 'usage: %s owner/model\n' "$0" >&2
    printf 'example: %s bytedance/seedream-4.5\n' "$0" >&2
    exit 2
fi

uv run python - "$1" <<'PY'
from __future__ import annotations

import html
import json
import re
import sys
from dataclasses import dataclass
from typing import Any
from urllib.error import HTTPError, URLError
from urllib.request import Request, urlopen


@dataclass(frozen=True)
class SchemaCandidate:
    version_id: str | None
    created_at: str | None
    schema: dict[str, Any]
    billing_config: dict[str, Any] | None = None
    model_name: str | None = None


def main() -> int:
    model = sys.argv[1]
    if "/" not in model:
        print(f"model must be in owner/model form, got: {model}", file=sys.stderr)
        return 2

    url = f"https://replicate.com/{model}/api/schema"
    page = fetch(url)
    model_latest_version = find_latest_version(page)
    latest_created_at = find_latest_created_at(page)
    candidates = dedupe_candidates(find_schema_candidates(page))

    print(f"# Replicate Schema: `{model}`")
    print()
    print(f"- Schema URL: <{url}>")
    if model_latest_version:
        print(f"- Page latest version: `{model_latest_version}`")
    if latest_created_at:
        print(f"- Page latest version created: `{latest_created_at}`")
    print(f"- Embedded schema candidates: {len(candidates)}")
    print()

    if not candidates:
        print("No embedded OpenAPI schema candidates found.", file=sys.stderr)
        return 1

    preferred = choose_candidate(candidates, model_latest_version)
    print_candidate_summary(preferred, preferred=True)

    alternatives = [candidate for candidate in candidates if candidate is not preferred]
    if alternatives:
        print("## Other Embedded Candidates")
        print()
        for candidate in alternatives:
            print_candidate_summary(candidate, preferred=False)

    return 0


def fetch(url: str) -> str:
    request = Request(
        url,
        headers={
            "Accept": "text/html,application/json",
            "User-Agent": "imagegen-schema-fetch/0.1",
        },
    )
    try:
        with urlopen(request, timeout=30) as response:
            return response.read().decode("utf-8", errors="replace")
    except HTTPError as error:
        raise SystemExit(f"HTTP {error.code} while fetching {url}") from error
    except URLError as error:
        raise SystemExit(f"Could not fetch {url}: {error.reason}") from error


def find_latest_version(page: str) -> str | None:
    matches = re.findall(r'"latest_version"\s*:\s*\{\s*"id"\s*:\s*"([^"]+)"', page)
    if not matches:
        return None
    return matches[-1]


def find_latest_created_at(page: str) -> str | None:
    match = re.search(r'replicate:latest_version_created_at"\s+content="([^"]+)"', page)
    if not match:
        return None
    return match.group(1)


def find_schema_candidates(page: str) -> list[SchemaCandidate]:
    candidates: list[SchemaCandidate] = []
    for script_body in iter_json_script_bodies(page):
        try:
            data = json.loads(html.unescape(script_body))
        except json.JSONDecodeError:
            continue
        billing_config = data.get("billingConfig") if isinstance(data, dict) else None
        if isinstance(data, dict) and isinstance(billing_config, dict):
            version = data.get("version")
            if isinstance(version, dict):
                candidate = schema_candidate_from_node(
                    version,
                    billing_config=billing_config,
                )
                if candidate is not None:
                    candidates.append(candidate)
        for node in walk(data):
            if not isinstance(node, dict):
                continue
            candidate = schema_candidate_from_node(node)
            if candidate is not None:
                candidates.append(candidate)
    return candidates


def schema_candidate_from_node(
    node: dict[str, Any],
    *,
    billing_config: dict[str, Any] | None = None,
) -> SchemaCandidate | None:
    extras = node.get("_extras")
    if not isinstance(extras, dict):
        return None
    schema = extras.get("dereferenced_openapi_schema")
    if not isinstance(schema, dict):
        return None
    version_id = node.get("id")
    created_at = node.get("created_at")
    return SchemaCandidate(
        version_id=version_id if isinstance(version_id, str) else None,
        created_at=created_at if isinstance(created_at, str) else None,
        schema=schema,
        billing_config=billing_config,
        model_name=model_name_from_extras(extras),
    )


def model_name_from_extras(extras: dict[str, Any]) -> str | None:
    model = extras.get("model")
    if not isinstance(model, dict):
        return None
    model_extras = model.get("_extras")
    if isinstance(model_extras, dict) and isinstance(model_extras.get("name"), str):
        return model_extras["name"]
    owner = model.get("owner")
    name = model.get("name")
    if isinstance(owner, str) and isinstance(name, str):
        return f"{owner}/{name}"
    return None


def dedupe_candidates(candidates: list[SchemaCandidate]) -> list[SchemaCandidate]:
    seen: dict[tuple[str | None, str], int] = {}
    deduped: list[SchemaCandidate] = []
    for candidate in candidates:
        schema_key = json.dumps(candidate.schema, sort_keys=True, separators=(",", ":"))
        key = (candidate.version_id, schema_key)
        previous_index = seen.get(key)
        if previous_index is not None:
            previous = deduped[previous_index]
            if previous.billing_config is None and candidate.billing_config is not None:
                deduped[previous_index] = candidate
            continue
        seen[key] = len(deduped)
        deduped.append(candidate)
    return deduped


def iter_json_script_bodies(page: str) -> list[str]:
    return re.findall(
        r'<script[^>]+type="application/json"[^>]*>(.*?)</script>',
        page,
        flags=re.S,
    )


def walk(value: Any) -> list[Any]:
    values: list[Any] = []
    stack = [value]
    while stack:
        current = stack.pop()
        values.append(current)
        if isinstance(current, dict):
            stack.extend(current.values())
        elif isinstance(current, list):
            stack.extend(current)
    return values


def choose_candidate(
    candidates: list[SchemaCandidate],
    latest_version: str | None,
) -> SchemaCandidate:
    for candidate in candidates:
        if candidate.billing_config is not None:
            return candidate
    if latest_version:
        for candidate in candidates:
            if candidate.version_id == latest_version:
                return candidate
    return candidates[0]


def print_candidate_summary(candidate: SchemaCandidate, *, preferred: bool) -> None:
    heading = "## Preferred Embedded Schema" if preferred else "### Candidate"
    print(heading)
    print()
    if candidate.version_id:
        print(f"- Version id: `{candidate.version_id}`")
    else:
        print("- Version id: not embedded with this schema")
    if candidate.created_at:
        print(f"- Created at: `{candidate.created_at}`")
    else:
        print("- Created at: not embedded with this schema")
    if candidate.model_name:
        print(f"- Embedded model: `{candidate.model_name}`")
    if candidate.billing_config is not None:
        print("- Pricing: associated with this embedded schema")
    print()

    input_schema = schema_component(candidate.schema, "Input")
    output_schema = schema_component(candidate.schema, "Output")

    if input_schema:
        print("### Input")
        print()
        required = input_schema.get("required", [])
        if required:
            print("- Required: " + ", ".join(f"`{name}`" for name in required))
        else:
            print("- Required: none")
        print()
        print("| Order | Name | Type | Default | Choices | Bounds | Description |")
        print("| ---: | --- | --- | --- | --- | --- | --- |")
        properties = input_schema.get("properties", {})
        for name, prop in sorted(
            properties.items(),
            key=lambda item: item[1].get("x-order", 999),
        ):
            print(parameter_row(name, prop, required))
        print()

    if output_schema:
        print("### Output")
        print()
        print(f"- Shape: {schema_type(output_schema)}")
        if isinstance(output_schema.get("items"), dict):
            print(f"- Items: {schema_type(output_schema['items'])}")
        print()

    if candidate.billing_config is not None:
        print("### Pricing")
        print()
        print("| Price | Title | Description | Type | Metric | Metric Count |")
        print("| --- | --- | --- | --- | --- | ---: |")
        for price in iter_prices(candidate.billing_config):
            print(pricing_row(price))
        print()

    print("### Registry Hints")
    print()
    if input_schema:
        for name, prop in sorted(
            input_schema.get("properties", {}).items(),
            key=lambda item: item[1].get("x-order", 999),
        ):
            hints = {
                "name": name,
                "type": registry_type(prop),
                "default": prop.get("default", ""),
                "choices": prop.get("enum", []),
                "minimum": prop.get("minimum"),
                "maximum": prop.get("maximum"),
                "order": prop.get("x-order"),
            }
            compact = {key: value for key, value in hints.items() if value not in (None, [], "")}
            print(f"- `{name}`: `{json.dumps(compact, ensure_ascii=False)}`")
    if candidate.billing_config is not None:
        print()
        print("#### Pricing")
        print()
        for price in iter_prices(candidate.billing_config):
            hints = {
                "price": price.get("price", ""),
                "title": price.get("title", ""),
                "description": price.get("description", ""),
                "type": price.get("type", ""),
                "metric": price.get("metric", ""),
                "metric_count": price.get("metric_count", 1),
            }
            compact = {key: value for key, value in hints.items() if value not in (None, "", [])}
            print(f"- `{json.dumps(compact, ensure_ascii=False)}`")
    print()


def schema_component(schema: dict[str, Any], name: str) -> dict[str, Any] | None:
    component = schema.get("components", {}).get("schemas", {}).get(name)
    return component if isinstance(component, dict) else None


def parameter_row(name: str, prop: dict[str, Any], required: list[str]) -> str:
    order = markdown_value(prop.get("x-order", ""))
    label = f"`{name}`"
    if name in required:
        label += " *"
    type_name = schema_type(prop)
    default = markdown_value(prop.get("default", ""))
    choices = ", ".join(f"`{choice}`" for choice in prop.get("enum", []))
    bounds = format_bounds(prop)
    description = markdown_value(prop.get("description", ""))
    return f"| {order} | {label} | {type_name} | {default} | {choices} | {bounds} | {description} |"


def iter_prices(billing_config: dict[str, Any]) -> list[dict[str, Any]]:
    prices: list[dict[str, Any]] = []
    for tier in billing_config.get("current_tiers", []):
        if not isinstance(tier, dict):
            continue
        for price in tier.get("prices", []):
            if isinstance(price, dict):
                prices.append(price)
    return prices


def pricing_row(price: dict[str, Any]) -> str:
    return (
        f"| {markdown_value(price.get('price', ''))} "
        f"| {markdown_value(price.get('title', ''))} "
        f"| {markdown_value(price.get('description', ''))} "
        f"| {markdown_value(price.get('type', ''))} "
        f"| {markdown_value(price.get('metric', ''))} "
        f"| {markdown_value(price.get('metric_count', 1))} |"
    )


def schema_type(prop: dict[str, Any]) -> str:
    type_name = prop.get("type", "unknown")
    item_schema = prop.get("items")
    if type_name == "array" and isinstance(item_schema, dict):
        return f"array[{schema_type(item_schema)}]"
    item_format = prop.get("format")
    if item_format:
        return f"{type_name}:{item_format}"
    return str(type_name)


def registry_type(prop: dict[str, Any]) -> str:
    if prop.get("enum"):
        return "select"
    type_name = prop.get("type")
    if type_name in {"array", "boolean", "integer", "number", "string"}:
        return str(type_name)
    return "string"


def format_bounds(prop: dict[str, Any]) -> str:
    minimum = prop.get("minimum")
    maximum = prop.get("maximum")
    if minimum is None and maximum is None:
        return ""
    if minimum is None:
        return f"<= `{maximum}`"
    if maximum is None:
        return f">= `{minimum}`"
    return f"`{minimum}`-`{maximum}`"


def markdown_value(value: Any) -> str:
    if value in (None, ""):
        return ""
    if isinstance(value, bool):
        return "`true`" if value else "`false`"
    if isinstance(value, (int, float)):
        return f"`{value}`"
    text = str(value).replace("|", "\\|").replace("\n", " ")
    return f"`{text}`"


raise SystemExit(main())
PY
